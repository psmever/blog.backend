{
  "preset": "laravel",
  "rules": {
    "no_unused_imports": true,
    "ordered_imports": {
      "sort_algorithm": "alpha"
    },
    "single_quote": true,
    "concat_space": {
      "spacing": "one"
    },
    "phpdoc_align": true,
    "phpdoc_separation": true,
    "phpdoc_summary": true
  },
  "exclude": [
    "storage",
    "bootstrap/cache"
  ]
}

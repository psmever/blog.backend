meta {
  name: 게시글 게시
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/api/v1/posts/:postUuid/publish
  body: none
  auth: bearer
}

headers {
  Accept: application/json
  Client-Type: {{clientType}}
}

auth:bearer {
  token: {{accessToken}}
}

params:path {
  postUuid: {{postUuid}}
}

script:post-response {
  if (res.status === 200 && res.body?.data?.slug) {
    bru.setEnvVar("postSlug", res.body.data.slug);
  }
}

docs {
  UUID로 게시글을 공개 상태로 전환하고 공개 슬러그를 현재 환경에 저장합니다.
}

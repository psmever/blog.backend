meta {
  name: 게시글 이미지 업로드
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/v1/posts/:postUuid/images
  body: multipartForm
  auth: bearer
}

headers {
  Accept: application/json
  Client-Type: {{clientType}}
}

auth:bearer {
  token: {{accessToken}}
}

params:path {
  postUuid: {{postUuid}}
}

body:multipart-form {
  ~image: @file()
}

docs {
  게시글에 이미지를 업로드합니다. Bruno 화면에서 image 항목을 활성화하고 로컬 파일을 선택하세요.
  허용 형식: jpeg, jpg, png, webp, gif
}

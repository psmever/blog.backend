meta {
  name: 전체 로그아웃
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/auth/logout/all
  body: none
  auth: bearer
}

headers {
  Accept: application/json
  Client-Type: {{clientType}}
}

auth:bearer {
  token: {{accessToken}}
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("accessToken", "");
    bru.setEnvVar("refreshToken", "");
  }
}

docs {
  현재 사용자의 모든 토큰을 폐기하고 환경의 토큰 값을 비웁니다.
}

meta {
  name: 로그아웃
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/auth/logout
  body: none
  auth: bearer
}

headers {
  Accept: application/json
  Client-Type: {{clientType}}
}

auth:bearer {
  token: {{accessToken}}
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("accessToken", "");
  }
}

docs {
  현재 액세스 토큰만 폐기합니다.
}
